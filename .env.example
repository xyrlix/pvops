# 应用配置
APP_NAME=PVOps
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production

# 后端服务
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=pvops
POSTGRES_PASSWORD=pvops_password
POSTGRES_DB=pvops
DATABASE_URL=postgresql+asyncpg://pvops:pvops_password@postgres:5432/pvops

# 时序数据库后端: sqlite | tdengine
TSDB_BACKEND=tdengine

# TDengine
TDENGINE_HOST=tdengine
TDENGINE_PORT=6030
TDENGINE_USER=root
TDENGINE_PASSWORD=taosdata
TDENGINE_DATABASE=pvops

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# MQTT
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# MinIO（可选）
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pvops

# Cloudflare Tunnel（可选，用于远程访问）
CF_TUNNEL_TOKEN=

# 大模型 API（OpenAI 兼容接口）
# 支持 openai / deepseek / kimi / qwen / minimax / custom
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Embedding（默认与 LLM 同 provider，也可单独指定）
EMBEDDING_PROVIDER=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

# 兼容旧变量名
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
