# PVOps 后端环境变量示例

# 业务数据库（默认 SQLite，生产请使用 PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///./pvops.db

# 时序数据库后端：sqlite | tdengine
TSDB_BACKEND=sqlite

# TDengine 连接信息（TSDB_BACKEND=tdengine 时生效）
TDENGINE_HOST=tdengine
TDENGINE_PORT=6030
TDENGINE_USER=root
TDENGINE_PASSWORD=taosdata
TDENGINE_DATABASE=pvops

# Redis
REDIS_URL=redis://redis:6379/0

# MQTT
MQTT_HOST=mosquitto
MQTT_PORT=1883

# LLM / Embedding（支持 OpenAI / DeepSeek / Kimi / Qwen / MiniMax 等 OpenAI 兼容接口）
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

EMBEDDING_PROVIDER=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

# Mock 数据开关：本地演示默认 true；接入真实数据后设为 false
USE_MOCK_DATA=true

# 安全
SECRET_KEY=change-me-in-production
